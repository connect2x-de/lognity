{
    "$schema": "../schema/Lognity Config V1.json",
    "version": 1,
    "level": "{DEFAULT_LOG_LEVEL}",
    "enabled": true,
    "conditions": [
        {
            "name": "default_condition",
            "type": "level",
            "condition": "ABOVE",
            "value": "TRACE"
        }
    ],
    "appenders": [
        {
            "type": "system_console",
            "name": "my_appender",
            "pattern": "{{levelColor}}>>  {{levelSymbol}}\t{{hh}}:{{mm}}:{{ss}}.{{SSS}} ({{name}} @ {{threadId}}) {{message}}{{r}}",
            "formatter": "default",
            "filter": {
                "conditions": [
                    {
                        "type": "marker",
                        "condition": "KEY_NOT_EQUALS",
                        "value": "marker1"
                    },
                    {
                        "type": "or",
                        "conditions": [
                            {
                                "type": "logger_name",
                                "condition": "CONTAINS",
                                "value": "My Filtered Logger"
                            },
                            "{conditions:default_condition}"
                        ]
                    }
                ]
            }
        },
        {
            "type": "rolling_file",
            "name": "my_file_appender",
            "base_path": "{LOG_DIRECTORY}/example.log",
            "pattern": "[{{level}}] {{hh}}:{{mm}}:{{ss}}.{{SSS}} ({{name}} @ {{threadId}}) {{message}}{{r}}",
            "formatter": "default",
            "filter": {
                "conditions": [
                    {
                        "type": "marker",
                        "condition": "KEY_NOT_EQUALS",
                        "value": "marker1"
                    },
                    {
                        "type": "logger_name",
                        "condition": "NOT_CONTAINS",
                        "value": "My Filtered Logger"
                    }
                ]
            }
        }
    ]
}