{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Lognity Config V1",
    "type": "object",
    "properties": {
        "version": {
            "type": "integer",
            "description": "The Lognity config version.",
            "minimum": 1,
            "default": 1
        },
        "level": {
            "oneOf": [
                {
                    "type": "string",
                    "enum": [
                        "TRACE",
                        "DEBUG",
                        "INFO",
                        "WARN",
                        "ERROR",
                        "FATAL"
                    ],
                    "default": "INFO",
                    "description": "The default log level of all loggers."
                },
                {
                    "type": "string",
                    "pattern": "^\\{([\\w\\-._]+)}$",
                    "default": "{MY_PROVIDER}"
                }
            ]
        },
        "enabled": {
            "oneOf": [
                {
                    "type": "boolean",
                    "description": "The default enable state of all loggers.",
                    "default": true
                },
                {
                    "type": "string",
                    "pattern": "^\\{([\\w\\-._]+)}$",
                    "default": "{MY_PROVIDER}"
                }
            ]
        },
        "appenders": {
            "type": "array",
            "description": "The list of default appenders added to all loggers.",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "console",
                            "file",
                            "rolling_file",
                            "system_console",
                            "system_log",
                            "os_log",
                            "logcat",
                            "winevent"
                        ],
                        "default": "system_console",
                        "description": "The type of appender."
                    },
                    "name": {
                        "oneOf": [
                            {
                                "type": "string",
                                "description": "The internal name this appender may be referenced by.",
                                "default": "my_appender"
                            },
                            {
                                "type": "string",
                                "pattern": "^\\{([\\w\\-._]+)}$",
                                "default": "{MY_PROVIDER}"
                            }
                        ]
                    },
                    "pattern": {
                        "oneOf": [
                            {
                                "type": "string",
                                "description": "The message pattern this appender uses for formatting log messages.",
                                "default": "{{message}}{{r}}"
                            },
                            {
                                "type": "string",
                                "pattern": "^\\{([\\w\\-._]+)}$",
                                "default": "{MY_PROVIDER}"
                            }
                        ]
                    },
                    "formatter": {
                        "oneOf": [
                            {
                                "type": "string",
                                "pattern": "^(?!\\{).*",
                                "description": "The formatter this appender invokes with the pattern to format messages.",
                                "default": "default"
                            },
                            {
                                "type": "string",
                                "pattern": "^\\{([\\w\\-._]+)}$",
                                "default": "{MY_PROVIDER}"
                            }
                        ]
                    },
                    "filter": {
                        "type": "object",
                        "description": "The filter which is applied to all messages before logging to this appender.",
                        "properties": {
                            "conditions": {
                                "type": "array",
                                "description": "A list of conditions applied in a ",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "type": {
                                            "type": "string",
                                            "enum": [
                                                "always",
                                                "or",
                                                "and",
                                                "exactly_one",
                                                "marker",
                                                "message",
                                                "level",
                                                "logger_name",
                                                "coroutine_name"
                                            ],
                                            "default": "always",
                                            "description": "The type of condition."
                                        },
                                        "name": {
                                            "oneOf": [
                                                {
                                                    "type": "string",
                                                    "description": "The internal name of the condition."
                                                },
                                                {
                                                    "type": "string",
                                                    "pattern": "^\\{([\\w\\-._]+)}$",
                                                    "default": "{MY_PROVIDER}"
                                                }
                                            ]
                                        }
                                    },
                                    "if": {
                                        "properties": {
                                            "type": {"const": "marker"}
                                        }
                                    },
                                    "then": {
                                        "properties": {
                                            "condition": {
                                                "oneOf": [
                                                    {
                                                        "type": "string",
                                                        "enum": [
                                                            "KEY_EQUALS",
                                                            "KEY_NOT_EQUALS",
                                                            "KEY_CONTAINS",
                                                            "KEY_NOT_CONTAINS",
                                                            "NAME_EQUALS",
                                                            "NAME_NOT_EQUALS",
                                                            "NAME_CONTAINS",
                                                            "NAME_NOT_CONTAINS"
                                                        ],
                                                        "default": "KEY_EQUALS",
                                                        "description": "The conditional rule to apply on every log marker."
                                                    },
                                                    {
                                                        "type": "string",
                                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                                        "default": "{MY_PROVIDER}"
                                                    }
                                                ]
                                            },
                                            "value": {
                                                "oneOf": [
                                                    {
                                                        "type": "string",
                                                        "description": "The literal string value to check all markers against."
                                                    },
                                                    {
                                                        "type": "string",
                                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                                        "default": "{MY_PROVIDER}"
                                                    }
                                                ]
                                            }
                                        },
                                        "required": [
                                            "condition",
                                            "value"
                                        ]
                                    },
                                    "else": {
                                        "if": {
                                            "properties": {
                                                "type": {"const": "message"}
                                            }
                                        },
                                        "then": {
                                            "properties": {
                                                "condition": {
                                                    "oneOf": [
                                                        {
                                                            "type": "string",
                                                            "enum": [
                                                                "EQUALS",
                                                                "NOT_EQUALS",
                                                                "CONTAINS",
                                                                "NOT_CONTAINS"
                                                            ],
                                                            "default": "EQUALS",
                                                            "description": "The conditional rule to apply to every log message."
                                                        },
                                                        {
                                                            "type": "string",
                                                            "pattern": "^\\{([\\w\\-._]+)}$",
                                                            "default": "{MY_PROVIDER}"
                                                        }
                                                    ]
                                                },
                                                "value": {
                                                    "oneOf": [
                                                        {
                                                            "type": "string",
                                                            "description": "The literal string value to check all messages against."
                                                        },
                                                        {
                                                            "type": "string",
                                                            "pattern": "^\\{([\\w\\-._]+)}$",
                                                            "default": "{MY_PROVIDER}"
                                                        }
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "condition",
                                                "value"
                                            ]
                                        },
                                        "else": {
                                            "if": {
                                                "properties": {
                                                    "type": {"const": "level"}
                                                }
                                            },
                                            "then": {
                                                "properties": {
                                                    "condition": {
                                                        "oneOf": [
                                                            {
                                                                "type": "string",
                                                                "enum": [
                                                                    "EQUALS",
                                                                    "NOT_EQUALS",
                                                                    "BELOW",
                                                                    "ABOVE"
                                                                ],
                                                                "default": "EQUALS",
                                                                "description": "The conditional rule to apply to all log levels."
                                                            },
                                                            {
                                                                "type": "string",
                                                                "pattern": "^\\{([\\w\\-._]+)}$",
                                                                "default": "{MY_PROVIDER}"
                                                            }
                                                        ]
                                                    },
                                                    "value": {
                                                        "oneOf": [
                                                            {
                                                                "type": "string",
                                                                "enum": [
                                                                    "TRACE",
                                                                    "DEBUG",
                                                                    "INFO",
                                                                    "WARN",
                                                                    "ERROR",
                                                                    "FATAL"
                                                                ],
                                                                "default": "INFO",
                                                                "description": "The log level to check all incoming log levels agsinst."
                                                            },
                                                            {
                                                                "type": "string",
                                                                "pattern": "^\\{([\\w\\-._]+)}$",
                                                                "default": "{MY_PROVIDER}"
                                                            }
                                                        ]
                                                    }
                                                },
                                                "required": [
                                                    "condition",
                                                    "value"
                                                ]
                                            },
                                            "else": {
                                                "if": {
                                                    "properties": {
                                                        "type": {"const": "logger_name"}
                                                    }
                                                },
                                                "then": {
                                                    "properties": {
                                                        "condition": {
                                                            "oneOf": [
                                                                {
                                                                    "type": "string",
                                                                    "enum": [
                                                                        "EQUALS",
                                                                        "NOT_EQUALS",
                                                                        "CONTAINS",
                                                                        "NOT_CONTAINS"
                                                                    ],
                                                                    "default": "EQUALS",
                                                                    "description": "The conditional rule to apply to every log message."
                                                                },
                                                                {
                                                                    "type": "string",
                                                                    "pattern": "^\\{([\\w\\-._]+)}$",
                                                                    "default": "{MY_PROVIDER}"
                                                                }
                                                            ]
                                                        },
                                                        "value": {
                                                            "oneOf": [
                                                                {
                                                                    "type": "string",
                                                                    "description": "The literal string value to check all logger names against."
                                                                },
                                                                {
                                                                    "type": "string",
                                                                    "pattern": "^\\{([\\w\\-._]+)}$",
                                                                    "default": "{MY_PROVIDER}"
                                                                }
                                                            ]
                                                        }
                                                    }
                                                },
                                                "else": {
                                                    "if": {
                                                        "properties": {
                                                            "type": {"const": "coroutine_name"}
                                                        }
                                                    },
                                                    "then": {
                                                        "properties": {
                                                            "condition": {
                                                                "oneOf": [
                                                                    {
                                                                        "type": "string",
                                                                        "enum": [
                                                                            "EQUALS",
                                                                            "NOT_EQUALS",
                                                                            "CONTAINS",
                                                                            "NOT_CONTAINS"
                                                                        ],
                                                                        "default": "EQUALS",
                                                                        "description": "The conditional rule to apply to every log message."
                                                                    },
                                                                    {
                                                                        "type": "string",
                                                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                                                        "default": "{MY_PROVIDER}"
                                                                    }
                                                                ]
                                                            },
                                                            "value": {
                                                                "oneOf": [
                                                                    {
                                                                        "type": "string",
                                                                        "description": "The literal string value to check all coroutine names against."
                                                                    },
                                                                    {
                                                                        "type": "string",
                                                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                                                        "default": "{MY_PROVIDER}"
                                                                    }
                                                                ]
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "required": ["type"]
                                }
                            }
                        }
                    }
                },
                "if": {
                    "properties": {
                        "type": {"const": "file"}
                    }
                },
                "then": {
                    "properties": {
                        "path": {
                            "oneOf": [
                                {
                                    "type": "string",
                                    "pattern": "^(?:\\.{1,2}|/)?(?:[^/]+|\\.{1,2})(?:/(?:[^/]+|\\.{1,2}))*/?$",
                                    "description": "The relative path to the log file for plain file appenders.",
                                    "default": "logs/my_log.log"
                                },
                                {
                                    "type": "string",
                                    "pattern": "^\\{([\\w\\-._]+)}$",
                                    "default": "{MY_PROVIDER}"
                                }
                            ]
                        }
                    },
                    "required": ["path"]
                },
                "else": {
                    "if": {
                        "properties": {
                            "type": {"const": "rolling_file"}
                        }
                    },
                    "then": {
                        "properties": {
                            "base_path": {
                                "oneOf": [
                                    {
                                        "type": "string",
                                        "pattern": "^(?:\\.{1,2}|/)?(?:[^/]+|\\.{1,2})(?:/(?:[^/]+|\\.{1,2}))*/?$",
                                        "description": "The base path of the rolling file segment files.",
                                        "default": "logs/my_log.log"
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                        "default": "{MY_PROVIDER}"
                                    }
                                ]
                            },
                            "file_count": {
                                "oneOf": [
                                    {
                                        "type": "integer",
                                        "description": "The number of files used as a ring buffer.",
                                        "default": 10
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                        "default": "{MY_PROVIDER}"
                                    }
                                ]
                            },
                            "max_file_size": {
                                "oneOf": [
                                    {
                                        "type": "integer",
                                        "description": "The maximum size of each segment file.",
                                        "default": 1048576
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                        "default": "{MY_PROVIDER}"
                                    }
                                ]
                            },
                            "use_timestamps": {
                                "oneOf": [
                                    {
                                        "type": "boolean",
                                        "description": "Whether this appender adds timestamps to the file name when updating segments.",
                                        "default": true
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                        "default": "{MY_PROVIDER}"
                                    }
                                ]
                            },
                            "delete_existing": {
                                "oneOf": [
                                    {
                                        "type": "boolean",
                                        "description": "Whether existing log files are deleted before logging begins.",
                                        "default": false
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                        "default": "{MY_PROVIDER}"
                                    }
                                ]
                            },
                            "latest_suffix": {
                                "oneOf": [
                                    {
                                        "type": "string",
                                        "pattern": "^[a-zA-Z\\-_.]+[a-zA-Z\\-_.0-9]*$",
                                        "description": "The suffix added to the last touched log file.",
                                        "default": "-latest"
                                    },
                                    {
                                        "type": "string",
                                        "pattern": "^\\{([\\w\\-._]+)}$",
                                        "default": "{MY_PROVIDER}"
                                    }
                                ]
                            }
                        },
                        "required": ["base_path"]
                    }
                },
                "required": [
                    "type",
                    "pattern",
                    "formatter"
                ]
            }
        }
    },
    "required": ["version"]
}