{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Lognity Config V1",
    "type": "object",
    "properties": {
        "version": {
            "type": "integer",
            "minimum": 1,
            "description": "The Lognity config version."
        },
        "level": {
            "type": "string",
            "enum": [
                "TRACE",
                "DEBUG",
                "INFO",
                "WARN",
                "ERROR",
                "FATAL"
            ],
            "description": "The default log level of all loggers."
        },
        "enabled": {
            "type": "boolean",
            "description": "The default enable state of all loggers."
        },
        "appenders": {
            "type": "array",
            "description": "The list of default appenders added to all loggers.",
            "items": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "console",
                            "file",
                            "system_log"
                        ],
                        "description": "The type of appender."
                    },
                    "name": {
                        "type": "string",
                        "description": "The internal name this appender may be referenced by."
                    },
                    "pattern": {
                        "type": "string",
                        "description": "The message pattern this appender uses for formatting log messages."
                    },
                    "formatter": {
                        "type": "string",
                        "description": "The formatter this appender invokes with the pattern to format messages."
                    },
                    "filter": {
                        "type": "object",
                        "description": "The filter which is applied to all messages before logging to this appender.",
                        "properties": {
                            "conditions": {
                                "type": "array",
                                "description": "A list of conditions applied in a ",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "type": {
                                            "type": "string",
                                            "enum": [
                                                "always",
                                                "marker",
                                                "message",
                                                "level"
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "path": {
                        "type": "string",
                        "description": "The relative path to the log file for file appenders."
                    },
                    "rolling": {
                        "type": "boolean",
                        "description": "For file appenders, automatically adds timestamps to the log files so they don't get overwritten."
                    }
                },
                "required": [
                    "type",
                    "pattern",
                    "formatter"
                ]
            }
        }
    },
    "required": [
        "version"
    ]
}